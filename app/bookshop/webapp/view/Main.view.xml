<mvc:View
  controllerName="my.bookstore.bookshop.controller.Main"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  displayBlock="true">

  <App>
    <pages>
      <Page title="SAP Business ByDesign Book Store" showNavButton="false">

        <headerContent>
          <Button text="Home" icon="sap-icon://home" press=".onHome" />
        </headerContent>

        <subHeader>
          <Bar>
            <contentMiddle>
              <SearchField
                id="searchField"
                placeholder="Search by title, author or category..."
                width="400px"
                search=".onSearch"
                liveChange=".onSearch" />
            </contentMiddle>
          </Bar>
        </subHeader>

        <content>
          <Table
            id="booksTable"
            items="{
              path: '/Books',
              parameters: { $expand: 'author', $orderby: 'title' }
            }"
            growing="true"
            growingThreshold="20"
            noDataText="No books found.">

            <headerToolbar>
              <OverflowToolbar>
                <Title text="Books" level="H3" />
                <ToolbarSpacer />
                <Text id="bookCount" text="" class="sapUiSmallMarginEnd" />
              </OverflowToolbar>
            </headerToolbar>

            <columns>
              <Column width="30%"><Text text="Title" /></Column>
              <Column width="18%"><Text text="Author" /></Column>
              <Column width="14%"><Text text="Category" /></Column>
              <Column width="8%"  hAlign="Center"><Text text="Year" /></Column>
              <Column width="10%" hAlign="End"><Text text="Price (EUR)" /></Column>
              <Column width="20%"><Text text="Description" /></Column>
            </columns>

            <items>
              <ColumnListItem>
                <cells>
                  <Text text="{title}" wrapping="false" maxLines="1" />
                  <Text text="{author/name}" />
                  <ObjectStatus text="{category}" state="Information" />
                  <Text text="{publicationYear}" />
                  <Text text="{
                    path: 'price',
                    type: 'sap.ui.model.odata.type.Decimal',
                    formatOptions: { style: 'standard', minimumFractionDigits: 2, maximumFractionDigits: 2 }
                  }" />
                  <Text text="{description}" wrapping="true" maxLines="2" />
                </cells>
              </ColumnListItem>
            </items>

          </Table>
        </content>

      </Page>
    </pages>
  </App>

</mvc:View>
