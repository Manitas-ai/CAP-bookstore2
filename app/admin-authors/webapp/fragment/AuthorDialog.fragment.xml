<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core">

  <Dialog title="Author" contentWidth="480px">
    <content>
      <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">

        <Label text="Name" required="true" class="sapUiTinyMarginBottom" />
        <Input id="inputName" placeholder="Full name" width="100%" class="sapUiSmallMarginBottom" />

        <Label text="Country" class="sapUiTinyMarginBottom" />
        <Input id="inputCountry" placeholder="e.g. Germany" width="100%" class="sapUiSmallMarginBottom" />

        <Label text="Biography" class="sapUiTinyMarginBottom" />
        <TextArea id="inputBio" placeholder="Short biography..." rows="5" width="100%" growing="true" />

      </VBox>
    </content>
    <beginButton>
      <Button text="Save" type="Emphasized" press=".onSaveAuthor" />
    </beginButton>
    <endButton>
      <Button text="Cancel" press=".onCancelDialog" />
    </endButton>
  </Dialog>

</core:FragmentDefinition>
