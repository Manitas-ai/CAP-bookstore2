{
  "name": "bookstore2",
  "version": "1.0.0",
  "description": "SAP Business ByDesign Book Store – Internal PoC",
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch"
  },
  "dependencies": {
    "@sap/cds": "^10"
  },
  "devDependencies": {
    "@sap/cds-dk": "^10",
    "@cap-js/sqlite": "^1"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      }
    },
    "[production]": {
      "requires": {
        "db": {
          "kind": "hana"
        }
      }
    }
  }
}
